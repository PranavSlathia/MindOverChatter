# Database
# DB_PASSWORD is required and is the single source of truth for Compose services.
DB_PASSWORD=change-me
DATABASE_URL=postgresql://moc:change-me@localhost:5433/moc

# Service URLs (internal Docker network)
WHISPER_SERVICE_URL=http://localhost:8001
EMOTION_SERVICE_URL=http://localhost:8002
TTS_SERVICE_URL=http://localhost:8003
MEMORY_SERVICE_URL=http://localhost:8004

# Claude (uses local binary auth, no API key needed)
CLAUDE_MODEL=sonnet
CLAUDE_HAIKU_MODEL=haiku

# Groq API key (required for Mem0 memory extraction via Llama 3.3 70B)
# Get one free at https://console.groq.com
GROQ_API_KEY=

# Mem0 memory service (services/memory)
# These are used inside Docker Compose; defaults match docker-compose.yml
# DB_HOST=db
# DB_PORT=5432
# DB_USER=moc
# DB_PASSWORD=change-me
# DB_NAME=moc

# Embedding
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# Server
PORT=3000
WS_PORT=3000
NODE_ENV=development

# File storage
AUDIO_STORAGE_PATH=/app/volumes/audio
MODEL_CACHE_PATH=/app/models
